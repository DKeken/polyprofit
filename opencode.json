{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "claude-flow": {
      "type": "local",
      "command": ["npx", "-y", "@claude-flow/cli@latest", "mcp", "start"],
      "environment": {
        "npm_config_update_notifier": "false",
        "CLAUDE_FLOW_MODE": "v3",
        "CLAUDE_FLOW_HOOKS_ENABLED": "true",
        "CLAUDE_FLOW_TOPOLOGY": "hierarchical-mesh",
        "CLAUDE_FLOW_MAX_AGENTS": "15",
        "CLAUDE_FLOW_MEMORY_BACKEND": "hybrid"
      }
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest", "--browser", "chromium"]
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  },
  "plugin": [
    "opencode-wakatime",
    "opencode-shell-strategy",
    "opencode-notifier"
  ],
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "todowrite": "allow",
    "question": "allow",
    "skill": "allow"
  }
}
